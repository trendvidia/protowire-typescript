{
  "name": "@trendvidia/protowire",
  "version": "0.0.0",
  "description": "TypeScript port of protowire — PXF text format, SBE binary, struct-tag protobuf, and API envelope.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./envelope": {
      "types": "./dist/envelope/index.d.ts",
      "import": "./dist/envelope/index.js"
    },
    "./pb": {
      "types": "./dist/pb/index.d.ts",
      "import": "./dist/pb/index.js"
    },
    "./pxf": {
      "types": "./dist/pxf/index.d.ts",
      "import": "./dist/pxf/index.js"
    },
    "./sbe": {
      "types": "./dist/sbe/index.d.ts",
      "import": "./dist/sbe/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
